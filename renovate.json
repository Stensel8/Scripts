{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "description": "Renovate handles all version updates for this repository",
  "schedule": [
    "at any time"
  ],
  "labels": [
    "dependencies",
    "renovate"
  ],
  "assignees": [
    "Stensel8"
  ],
  "reviewers": [
    "Stensel8"
  ],
  "prConcurrentLimit": 5,
  "rebaseWhen": "behind-base-branch",
  "semanticCommits": "enabled",
  "automerge": true,
  "automergeType": "pr",
  "gitIgnoredAuthors": [
    "github-actions[bot]@users.noreply.github.com",
    "41898282+github-actions[bot]@users.noreply.github.com"
  ],
  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "semanticCommitType": "ci",
      "groupName": "GitHub Actions"
    },
    {
      "matchManagers": ["dockerfile", "docker-compose"],
      "semanticCommitType": "deps",
      "groupName": "Docker"
    },
    {
      "description": "Groepeer alle nginx installer-afhankelijkheden in één PR",
      "matchManagers": ["custom.regex"],
      "matchFileNames": ["nginx/**"],
      "semanticCommitType": "deps",
      "groupName": "nginx installer deps"
    },
    {
      "matchManagers": ["custom.regex"],
      "matchFileNames": ["ansible/**"],
      "semanticCommitType": "deps",
      "groupName": "ansible installer deps"
    },
    {
      "matchManagers": ["custom.regex"],
      "matchFileNames": ["kubernetes/**"],
      "semanticCommitType": "deps",
      "groupName": "kubernetes installer deps"
    }
  ],
  "customManagers": [
    {
      "description": "NGINX versie in bash installer",
      "customType": "regex",
      "managerFilePatterns": [
        "/^nginx/nginx_installer\\.sh$/"
      ],
      "matchStrings": ["NGINX_VERSION=\"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "nginx/nginx",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^release-(?<version>.+)$"
    },
    {
      "description": "NGINX versie in PowerShell installer",
      "customType": "regex",
      "managerFilePatterns": [
        "/^nginx/nginx_installer\\.ps1$/"
      ],
      "matchStrings": ["\\$Script:NGINX_VERSION\\s*=\\s*'(?<currentValue>[^']+)'"],
      "depNameTemplate": "nginx/nginx",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^release-(?<version>.+)$"
    },
    {
      "description": "OpenSSL versie in bash installer",
      "customType": "regex",
      "managerFilePatterns": [
        "/^nginx/nginx_installer\\.sh$/"
      ],
      "matchStrings": ["OPENSSL_VERSION=\"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "openssl/openssl",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^openssl-(?<version>.+)$"
    },
    {
      "description": "OpenSSL versie in PowerShell installer",
      "customType": "regex",
      "managerFilePatterns": [
        "/^nginx/nginx_installer\\.ps1$/"
      ],
      "matchStrings": ["\\$Script:OPENSSL_VERSION\\s*=\\s*'(?<currentValue>[^']+)'"],
      "depNameTemplate": "openssl/openssl",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^openssl-(?<version>.+)$"
    },
    {
      "description": "PCRE2 versie in bash installer",
      "customType": "regex",
      "managerFilePatterns": [
        "/^nginx/nginx_installer\\.sh$/"
      ],
      "matchStrings": ["PCRE2_VERSION=\"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "PCRE2Project/pcre2",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^pcre2-(?<version>.+)$"
    },
    {
      "description": "PCRE2 versie in PowerShell installer",
      "customType": "regex",
      "managerFilePatterns": [
        "/^nginx/nginx_installer\\.ps1$/"
      ],
      "matchStrings": ["\\$Script:PCRE2_VERSION\\s*=\\s*'(?<currentValue>[^']+)'"],
      "depNameTemplate": "PCRE2Project/pcre2",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^pcre2-(?<version>.+)$"
    },
    {
      "description": "Zlib versie in bash installer",
      "customType": "regex",
      "managerFilePatterns": [
        "/^nginx/nginx_installer\\.sh$/"
      ],
      "matchStrings": ["ZLIB_VERSION=\"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "madler/zlib",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "description": "Zlib versie in PowerShell installer",
      "customType": "regex",
      "managerFilePatterns": [
        "/^nginx/nginx_installer\\.ps1$/"
      ],
      "matchStrings": ["\\$Script:ZLIB_VERSION\\s*=\\s*'(?<currentValue>[^']+)'"],
      "depNameTemplate": "madler/zlib",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "description": "headers-more-nginx-module versie in bash installer",
      "customType": "regex",
      "managerFilePatterns": [
        "/^nginx/nginx_installer\\.sh$/"
      ],
      "matchStrings": ["HEADERS_MORE_VERSION=\"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "openresty/headers-more-nginx-module",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "description": "headers-more-nginx-module versie in PowerShell installer",
      "customType": "regex",
      "managerFilePatterns": [
        "/^nginx/nginx_installer\\.ps1$/"
      ],
      "matchStrings": ["\\$Script:HEADERS_MORE_VERSION\\s*=\\s*'(?<currentValue>[^']+)'"],
      "depNameTemplate": "openresty/headers-more-nginx-module",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "description": "zstd-nginx-module versie in bash installer",
      "customType": "regex",
      "managerFilePatterns": [
        "/^nginx/nginx_installer\\.sh$/"
      ],
      "matchStrings": ["ZSTD_MODULE_VERSION=\"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "tokers/zstd-nginx-module",
      "datasourceTemplate": "github-releases"
    },
    {
      "description": "zstd-nginx-module versie in PowerShell installer",
      "customType": "regex",
      "managerFilePatterns": [
        "/^nginx/nginx_installer\\.ps1$/"
      ],
      "matchStrings": ["\\$Script:ZSTD_MODULE_VERSION\\s*=\\s*'(?<currentValue>[^']+)'"],
      "depNameTemplate": "tokers/zstd-nginx-module",
      "datasourceTemplate": "github-releases"
    },
    {
      "description": "nginx-acme versie in bash installer",
      "customType": "regex",
      "managerFilePatterns": [
        "/^nginx/nginx_installer\\.sh$/"
      ],
      "matchStrings": ["ACME_MODULE_VERSION=\"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "nginx/nginx-acme",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "description": "nginx-acme versie in PowerShell installer",
      "customType": "regex",
      "managerFilePatterns": [
        "/^nginx/nginx_installer\\.ps1$/"
      ],
      "matchStrings": ["\\$Script:ACME_MODULE_VERSION\\s*=\\s*'(?<currentValue>[^']+)'"],
      "depNameTemplate": "nginx/nginx-acme",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "description": "Ansible versie in bash installer",
      "customType": "regex",
      "managerFilePatterns": [
        "/^ansible/ansible_installer\\.sh$/"
      ],
      "matchStrings": ["pip install ansible==(?<currentValue>[0-9.]+)"],
      "depNameTemplate": "ansible",
      "datasourceTemplate": "pypi"
    },
    {
      "description": "Kubernetes versie in bash installer",
      "customType": "regex",
      "managerFilePatterns": [
        "/^kubernetes/kubernetes_installer\\.sh$/"
      ],
      "matchStrings": ["K8S_VERSION:-(?<currentValue>v[0-9.]+)"],
      "depNameTemplate": "kubernetes/kubernetes",
      "datasourceTemplate": "github-releases"
    },
    {
      "description": "Request Python versie in ansible installer",
      "customType": "regex",
      "managerFilePatterns": ["/^ansible/ansible_installer\\.sh$/"],
      "matchStrings": ["REQ_PYTHON_VERSION=\"(?<currentValue>[0-9.]+)\""] ,
      "depNameTemplate": "python",
      "datasourceTemplate": "py"
    },
    {
      "description": "Build Python versie in ansible installer",
      "customType": "regex",
      "managerFilePatterns": ["/^ansible/ansible_installer\\.sh$/"],
      "matchStrings": ["BUILD_PYTHON_VERSION=\"(?<currentValue>[0-9.]+)\""] ,
      "depNameTemplate": "python",
      "datasourceTemplate": "py"
    },
    {
      "description": "Vagrant versie in Windows installer",
      "customType": "regex",
      "managerFilePatterns": ["/^windows/Install-VagrantVMware\\.ps1$/"],
      "matchStrings": ["\\$VAGRANT_VERSION\\s*=\\s*\"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "hashicorp/vagrant",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": [
      "security"
    ]
  }
}
